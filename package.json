{
  "name": "librowcag-cli",
  "version": "1.2.1",
  "description": "Global CLI wrapper for Libro.AgentWCAG skill installation.",
  "license": "MIT",
  "homepage": "https://github.com/BookHsu/Libro.AgentWCAG",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BookHsu/Libro.AgentWCAG.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "apply-release-version": "python scripts/apply-release-version.py",
    "prepack": "python scripts/write-package-provenance.py"
  },
  "bin": {
    "libro": "bin/libro.js"
  },
  "files": [
    "bin/",
    "package-provenance.json",
    "mcp-server/requirements.txt",
    "mcp-server/server.py",
    "mcp-server/tools/*.py",
    "scripts/*.py",
    "scripts/*.ps1",
    "scripts/*.sh",
    "skills/libro-wcag/SKILL.md",
    "skills/libro-wcag/adapters/",
    "skills/libro-wcag/agents/",
    "skills/libro-wcag/references/",
    "skills/libro-wcag/schemas/",
    "skills/libro-wcag/scripts/*.py",
    "skills/libro-wcag/scripts/py.typed"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "wcag",
    "accessibility",
    "a11y",
    "claude",
    "gemini",
    "copilot",
    "codex"
  ]
}
